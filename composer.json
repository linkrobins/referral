{
    "name": "linkrobins/referral",
    "description": "Invite code referral system for Flarum 2.0.",
    "type": "flarum-extension",
    "license": "MIT",
    "authors": [
        {
            "name": "Karl Bullock",
            "email": "karl@linkrobins.com"
        }
    ],
    "require": {
        "php": "^8.3",
        "flarum/core": "^2.0"
    },
    "autoload": {
